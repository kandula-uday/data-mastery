# Environment Variables Example
# Copy this file to .env and fill in your values

# Databricks Configuration
DATABRICKS_HOST=https://community.cloud.databricks.com
DATABRICKS_TOKEN=your-token-here
DATABRICKS_CLUSTER_ID=your-cluster-id
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id

# Project Configuration
PROJECT_NAME=lakehouse-taxi
ENVIRONMENT=dev

# Data Paths (DBFS)
BRONZE_PATH=dbfs:/FileStore/lakehouse/bronze/
SILVER_PATH=dbfs:/FileStore/lakehouse/silver/
GOLD_PATH=dbfs:/FileStore/lakehouse/gold/

# Local Data Paths
LOCAL_RAW_DATA=./data/raw/
LOCAL_PROCESSED_DATA=./data/processed/

# Great Expectations
GE_ROOT_DIR=./great_expectations/

# Logging
LOG_LEVEL=INFO
